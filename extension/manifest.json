{
  "manifest_version": 3,
  "name": "Match Laboral - LinkedIn Helper",
  "version": "0.1.0",
  "description": "Analiza el puesto visible de LinkedIn contra un perfil validado por el usuario.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analizar puesto visible"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://www.linkedin.com/*", "http://localhost:3000/*"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
